# Copy to `.env` (git-ignored) and fill in real values. Never commit `.env`.

# Neon Postgres connection string (server-only — never exposed to the client).
DATABASE_URL='postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require'

# Secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET='replace-with-a-long-random-hex-string'
